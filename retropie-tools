    def plugin_dependencies_text(self, plugin):
        deps = plugin.get("requires", [])

        if not deps:
            return "Aucune dépendance déclarée."

        lines = []

        for dep in deps:
            found = shutil.which(dep)
            if found:
                lines.append(f"✅ {dep} : {found}")
            else:
                lines.append(f"❌ {dep} : absent")

        return "\n".join(lines)

    def plugin_detail_menu(self, plugin):
        while True:
            name = plugin.get("name", "Plugin")

            choice = self.ui.menu(
                name,
                "Plugin sélectionné",
                [
                    ("1", "Lancer"),
                    ("2", "À propos"),
                    ("3", "Dépendances"),
                    ("0", "Retour"),
                ],
            )

            if choice == "1":
                runner = plugin.get("run")
                if callable(runner):
                    runner(self)
                else:
                    self.ui.msg(name, "Ce plugin ne possède pas de fonction run().")

            elif choice == "2":
                status_fn = plugin.get("status")
                status_text = "Non disponible"

                if callable(status_fn):
                    try:
                        st = status_fn()
                        status_text = f"{st.get('state', 'unknown').upper()} - {st.get('message', '')}"
                    except Exception as exc:
                        status_text = f"ERROR - {exc}"

                self.ui.msg(
                    name,
                    "ID : {id}\n"
                    "Nom : {name}\n"
                    "Description : {description}\n"
                    "Version : {version}\n"
                    "Auteur : {author}\n"
                    "Ordre : {order}\n"
                    "Chemin : {path}\n\n"
                    "État : {status}".format(
                        id=plugin.get("id", ""),
                        name=plugin.get("name", ""),
                        description=plugin.get("description", ""),
                        version=plugin.get("version", ""),
                        author=plugin.get("author", ""),
                        order=plugin.get("order", ""),
                        path=plugin.get("path", ""),
                        status=status_text,
                    )
                )

            elif choice == "3":
                self.ui.msg(
                    f"Dépendances - {name}",
                    self.plugin_dependencies_text(plugin)
                )

            elif choice in ("0", None):
                return

    def plugins_menu(self):
        plugins = discover_plugins()

        if not plugins:
            self.ui.msg("Plugins", "Aucun plugin détecté.")
            return

        plugins = sorted(plugins, key=lambda p: p.get("order", 999))

        items = []
        plugin_by_key = {}

        for index, plugin in enumerate(plugins, start=1):
            key = str(index)
            label = f"{plugin.get('name', plugin.get('id', 'Plugin'))} - {plugin.get('description', '')}"
            items.append((key, label))
            plugin_by_key[key] = plugin

        items.append(("0", "Retour"))

        while True:
            choice = self.ui.menu(
                "🧩 Plugins",
                "Plugins détectés automatiquement",
                items,
                height=24,
                width=90,
                menu_height=14,
            )

            if choice in ("0", None):
                return

            plugin = plugin_by_key.get(choice)

            if plugin:
                self.plugin_detail_menu(plugin)

