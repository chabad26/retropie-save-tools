    def harvest_manuals(self):
        system = self.choose_system("Moissonneuse V3", allow_all=True)

        if not system:
            return

        if system == "__ALL__":
            cmd = [MANUELS / "scripts/moissonner-manuels-v3-cute.py", "--all"]
        else:
            cmd = [MANUELS / "scripts/moissonner-manuels-v3-cute.py", system]

        if self.ui.yesno("Télécharger réellement les PDF ?"):
            cmd.append("--download")
        else:
            cmd.append("--debug")

        sleep = self.ui.input("Pause", "Pause entre requêtes :", "4")

        if sleep is None:
            return

        if sleep == "":
            sleep = "4"

        cmd.extend(["--sleep", sleep])

        self.run_cmd(cmd)

    def check_manuals(self):
        cmd = [MANUELS / "scripts/check-manuels.py", "--only-problems"]

        if self.ui.yesno("Vérifier aussi les liens gamelist.xml ?"):
            cmd.append("--check-gamelists")

        self.run_cmd(cmd)

