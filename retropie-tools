class DialogUI:
    def __init__(self):
        self.dialogrc = Path.home() / ".cache/retropie-tools/dialogrc"
        self.dialogrc.parent.mkdir(parents=True, exist_ok=True)
        self.dialogrc.write_text("""
use_shadow = ON
screen_color = (WHITE,BLACK,ON)
shadow_color = (BLACK,BLACK,ON)
dialog_color = (WHITE,BLACK,OFF)
title_color = (CYAN,BLACK,ON)
border_color = (CYAN,BLACK,ON)
button_active_color = (BLACK,CYAN,ON)
button_inactive_color = (WHITE,BLACK,OFF)
menubox_color = (WHITE,BLACK,OFF)
menubox_border_color = (CYAN,BLACK,ON)
item_color = (WHITE,BLACK,OFF)
item_selected_color = (BLACK,CYAN,ON)
tag_color = (CYAN,BLACK,ON)
tag_selected_color = (BLACK,CYAN,ON)
""", encoding="utf-8")
        os.environ["DIALOGRC"] = str(self.dialogrc)

    def check(self):
        if subprocess.call(["which", "dialog"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) != 0:
            print("dialog absent. Installe-le avec : sudo apt install -y dialog")
            sys.exit(1)

    def menu(self, title, text, items, height=22, width=78, menu_height=12):
        self.check()
        with tempfile.NamedTemporaryFile(delete=False) as tmp:
            output = tmp.name

        cmd = [
            "dialog",
            "--clear",
            "--backtitle", "RetroPie Save Tools",
            "--title", title,
            "--menu", text,
            str(height), str(width), str(menu_height),
        ]

        for key, label in items:
            cmd.extend([str(key), str(label)])

        result = subprocess.call(cmd, stderr=open(output, "w"))
        choice = Path(output).read_text().strip()
        Path(output).unlink(missing_ok=True)

        if result != 0:
            return "0"

        return choice

    def yesno(self, question):
        return subprocess.call([
            "dialog",
            "--backtitle", "RetroPie Save Tools",
            "--title", "Confirmation",
            "--yesno", question,
            "8", "70",
        ]) == 0

    def input(self, title, question, default=""):
        with tempfile.NamedTemporaryFile(delete=False) as tmp:
            output = tmp.name

        result = subprocess.call([
            "dialog",
            "--backtitle", "RetroPie Save Tools",
            "--title", title,
            "--inputbox", question,
            "8", "78",
            default,
        ], stderr=open(output, "w"))

        value = Path(output).read_text().strip()
        Path(output).unlink(missing_ok=True)

        if result != 0:
            return None

        return value

    def msg(self, title, message):
        subprocess.call([
            "dialog",
            "--backtitle", "RetroPie Save Tools",
            "--title", title,
            "--msgbox", message,
            "18", "78",
        ])

    def textbox(self, title, path):
        path = Path(path)

        if not path.is_file():
            self.msg(title, f"Fichier introuvable :\n{path}")
            return

        subprocess.call([
            "dialog",
            "--backtitle", "RetroPie Save Tools",
            "--title", title,
            "--textbox", str(path),
            "30", "120",
        ])


class App:
    def __init__(self):
        self.ui = DialogUI()

    def reload_settings(self):
        global SETTINGS
        SETTINGS = load_settings()

    def run_action(self, fn, *args, **kwargs):
        os.system("clear")
        try:
            fn(*args, **kwargs)
        except KeyboardInterrupt:
            print("\nInterruption demandée.")
        input("\nAppuie sur Entrée pour revenir au menu...")

    def run_cmd(self, cmd):
        os.system("clear")
        print("Commande :")
        print(" ".join(map(str, cmd)))
        print()

        try:
            subprocess.call([str(x) for x in cmd])
        except KeyboardInterrupt:
            print("\nInterruption demandée.")

        input("\nAppuie sur Entrée pour revenir au menu...")

    def get_systems(self):
        systems = set()

        if ES_CFG.is_file():
            try:
                root = ET.parse(ES_CFG).getroot()
                for node in root.findall("system"):
                    name = (node.findtext("name") or "").strip()
                    if name:
                        systems.add(name)
            except Exception:
                pass

        if not systems and INPUT_CSV.is_file():
            with INPUT_CSV.open("r", encoding="utf-8", newline="") as file:
                reader = csv.DictReader(file)
                for row in reader:
                    system = (row.get("system") or "").strip()
                    if system:
                        systems.add(system)

        return sorted(systems)

    def choose_system(self, title="Choisir une console", allow_all=False):
        systems = self.get_systems()

        if not systems:
            self.ui.msg("Erreur", "Aucune console trouvée.\nVérifie es_systems.cfg ou le CSV des manuels.")
            return ""

        items = []

        if allow_all:
            items.append(("__ALL__", "Toutes les consoles"))

        for system in systems:
            items.append((system, system))

        return self.ui.menu("🎮 " + title, "Consoles disponibles", items, height=28, width=78, menu_height=18)

